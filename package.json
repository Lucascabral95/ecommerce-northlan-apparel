{
  "name": "northlane-apparel",
  "version": "0.1.0",
  "private": true,
  "description": "Event-driven apparel e-commerce monorepo built with NestJS, RabbitMQ, PostgreSQL, Redis and npm workspaces.",
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "node scripts/clean.mjs",
    "db:migrate": "node scripts/migrations/run-migrations.mjs",
    "db:seed": "node scripts/seed/run-seed.mjs",
    "dev": "npm run build --workspace=@northlane/shared && turbo run dev --parallel --filter=@northlane/api-gateway --filter=@northlane/base-service",
    "docker:build": "docker compose build",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.7"
  }
}
