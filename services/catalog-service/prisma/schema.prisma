generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("CATALOG_DATABASE_URL")
}

enum GenderTarget {
  MEN
  WOMEN
  UNISEX
  KIDS
}

enum ProductType {
  T_SHIRT
  SHIRT
  PANTS
  JEANS
  JACKET
  HOODIE
  SWEATER
  DRESS
  SHOES
  ACCESSORY
  OTHER
}

enum ProductFit {
  SLIM
  REGULAR
  OVERSIZED
  RELAXED
}

enum ProductSeason {
  SUMMER
  WINTER
  MID_SEASON
  ALL_SEASON
}

model Brand {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("collections")
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  slug        String     @unique
  parentId    String?    @map("parent_id") @db.Uuid
  description String?
  imageUrl    String?    @map("image_url")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]  @relation("ProductCategory")
  subcategoryProducts Product[] @relation("ProductSubcategory")

  @@index([parentId])
  @@map("categories")
}

model Product {
  id                 String           @id @default(uuid()) @db.Uuid
  title              String
  slug               String           @unique
  skuBase            String           @unique @map("sku_base")
  brand              String
  categoryId         String           @map("category_id") @db.Uuid
  categoryName       String           @map("category_name")
  subcategoryId      String?          @map("subcategory_id") @db.Uuid
  subcategoryName    String?          @map("subcategory_name")
  genderTarget       GenderTarget     @map("gender_target")
  productType        ProductType      @map("product_type")
  shortDescription   String           @map("short_description")
  description        String
  material           String
  composition        String
  careInstructions   String           @map("care_instructions")
  fit                ProductFit
  season             ProductSeason
  collection         String?
  tags               String[]         @default([])
  price              Decimal          @db.Decimal(12, 2)
  compareAtPrice     Decimal?         @map("compare_at_price") @db.Decimal(12, 2)
  currency           String           @default("USD")
  costPrice          Decimal?         @map("cost_price") @db.Decimal(12, 2)
  taxRate            Decimal          @default(0.21) @map("tax_rate") @db.Decimal(5, 4)
  discountPercentage Decimal          @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  isActive           Boolean          @default(true) @map("is_active")
  isFeatured         Boolean          @default(false) @map("is_featured")
  isNewArrival       Boolean          @default(false) @map("is_new_arrival")
  isBestSeller       Boolean          @default(false) @map("is_best_seller")
  externalUrl        String?          @map("external_url")
  canonicalUrl       String?          @map("canonical_url")
  seoTitle           String?          @map("seo_title")
  seoDescription     String?          @map("seo_description")
  averageRating      Decimal          @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalReviews       Int              @default(0) @map("total_reviews")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  category           Category         @relation("ProductCategory", fields: [categoryId], references: [id])
  subcategory        Category?        @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  variants           ProductVariant[]
  images             ProductImage[]

  @@index([brand])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([genderTarget])
  @@index([productType])
  @@index([isActive, isFeatured])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id             String         @id @default(uuid()) @db.Uuid
  productId      String         @map("product_id") @db.Uuid
  sku            String         @unique
  colorName      String         @map("color_name")
  colorHex       String         @map("color_hex")
  size           String
  barcode        String?
  priceOverride  Decimal?       @map("price_override") @db.Decimal(12, 2)
  stock          Int            @default(0)
  reservedStock  Int            @default(0) @map("reserved_stock")
  weightInGrams  Int            @map("weight_in_grams")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images         ProductImage[]

  @@index([productId])
  @@index([colorName])
  @@index([size])
  @@map("product_variants")
}

model ProductImage {
  id        String          @id @default(uuid()) @db.Uuid
  productId String          @map("product_id") @db.Uuid
  variantId String?         @map("variant_id") @db.Uuid
  url       String
  altText   String          @map("alt_text")
  position  Int             @default(0)
  isPrimary Boolean         @default(false) @map("is_primary")
  createdAt DateTime        @default(now()) @map("created_at")
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_images")
}
