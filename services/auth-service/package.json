{
  "name": "@northlane/auth-service",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.json && node ../../scripts/copy-directory.mjs src/generated/prisma dist/generated/prisma",
    "clean": "node ../../scripts/clean.mjs",
    "dev": "npm run prisma:generate && tsx watch src/main.ts",
    "lint": "eslint .",
    "prisma:generate": "node ../../scripts/prisma-generate.mjs prisma/schema.prisma AUTH_DATABASE_URL postgresql://northlane:northlane@localhost:5432/northlane_platform?schema=auth_service",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests --exclude dist/**"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@northlane/contracts": "0.1.0",
    "@northlane/shared": "0.1.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "tsx": "^4.19.2"
  }
}
